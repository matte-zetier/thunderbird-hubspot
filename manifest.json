{
  "manifest_version": 2,
  "name": "Thunderbird HubSpot",
  "version": "0.1.0",
  "description": "HubSpot CRM integration for Thunderbird — log emails, surface contact context, and sync activity.",
  "browser_specific_settings": {
    "gecko": {
      "id": "thunderbird-hubspot@zetier.com",
      "strict_min_version": "91.0"
    }
  },
  "background": {
    "scripts": ["background/index.js"]
  },
  "message_display_action": {
    "default_title": "HubSpot",
    "default_popup": "popup/message-display/index.html",
    "default_icon": {
      "16": "icons/hubspot-16.svg",
      "32": "icons/hubspot-32.svg"
    }
  },
  "compose_action": {
    "default_title": "HubSpot",
    "default_popup": "popup/compose/index.html",
    "default_icon": {
      "16": "icons/hubspot-16.svg",
      "32": "icons/hubspot-32.svg"
    }
  },
  "options_ui": {
    "page": "options/index.html",
    "browser_style": false
  },
  "permissions": [
    "messagesRead",
    "compose",
    "storage",
    "https://api.hubapi.com/*"
  ]
}
